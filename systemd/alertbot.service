[Unit]
Description=Alert Bot Safe Reservation Monitor
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/Alert-bot-safe
EnvironmentFile=-/home/pi/Alert-bot-safe/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/Alert-bot-safe/.venv/bin/python -m alertbot
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target